<!DOCTYPE html>
<html lang="fr">
<head>
  <!-- Métadonnées essentielles : encodage UTF-8 et compatibilité mobile -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Titre dynamique passé depuis le serveur (EJS) -->
  <title><%= title %></title>
  
  <!-- Bootstrap CSS (version 5.3) pour la mise en page responsive -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  
  <!-- Feuille de style personnalisée (à placer dans /public/css/style.css) -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Inclusion du fichier partiel 'header' (ex: barre de navigation) -->
  <%- include('partials/header') %>
  
  <!-- Conteneur principal avec marge haute (mt-4) pour l'espacement -->
  <div class="container mt-4">
    <!-- Contenu spécifique de chaque page, injecté par le moteur de template -->
    <%- body %>
  </div>
  
  <!-- Inclusion du pied de page (footer) -->
  <%- include('partials/footer') %>
  
  <!-- Bundle JavaScript de Bootstrap (nécessaire pour les composants interactifs) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>